{
  "name": "@codejoo/mocker",
  "version": "0.1.0",
  "description": "Lightweight mock server for frontend dev — Vite plugin, decorator-based routing, hot reload, proxy fallback, auth, and scenario branching.",
  "keywords": [
    "mock",
    "mock-server",
    "mock-api",
    "vite",
    "vite-plugin",
    "dev-server",
    "hono",
    "bun",
    "decorators",
    "hot-reload",
    "proxy",
    "auth",
    "scenario",
    "frontend",
    "typescript",
    "type-safe"
  ],
  "license": "MIT",
  "author": "icodejoo",
  "type": "module",
  "main": "./dist/helpers.mjs",
  "module": "./dist/helpers.mjs",
  "types": "./dist/helpers.d.mts",
  "exports": {
    "./vite": {
      "types": "./dist/vite-plugin.d.mts",
      "import": "./dist/vite-plugin.mjs",
      "default": "./dist/vite-plugin.mjs"
    },
    "./helpers": {
      "types": "./dist/helpers.d.mts",
      "import": "./dist/helpers.mjs",
      "default": "./dist/helpers.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "tools/cli.ts",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "mocker": "./tools/cli.ts"
  },
  "scripts": {
    "fmt": "vp fmt -c oxfmt.config.ts",
    "lint": "vp lint -c oxlint.config.ts",
    "check": "vp fmt -c oxfmt.config.ts --check && vp lint -c oxlint.config.ts",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "start": "bun run tools/cli.ts",
    "test": "bun test"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "hono": "^4.0.0"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "vite-plus": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icodejoo/codejoo.git",
    "directory": "apps/mocker"
  },
  "homepage": "https://github.com/icodejoo/codejoo/tree/main/apps/mocker",
  "bugs": {
    "url": "https://github.com/icodejoo/codejoo/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
