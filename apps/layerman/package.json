{
  "name": "@codejoo/layerman",
  "version": "0.0.2",
  "description": "Framework-agnostic headless overlay/dialog/modal/bottom-sheet/drawer queue manager: serial one-at-a-time queue with named slots, priority/replace/overlap/affix, per-overlay conditions (route/auth/predicate) and cooldown (session/day/hour/minute/total/min-gap), backend-driven async resolve, imperative promise results, two-phase close, injectable async storage, cross-tab cooldown sync — zero runtime deps, no DOM.",
  "keywords": [
    "bottom-sheet",
    "cooldown",
    "dialog",
    "drawer",
    "framework-agnostic",
    "headless",
    "modal",
    "overlay",
    "popup",
    "priority",
    "queue",
    "toast",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icodejoo/codejoo.git",
    "directory": "apps/layerman"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "README.zh-CN.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/esm/index.mjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "default": "./dist/esm/index.mjs"
    },
    "./vue": {
      "types": "./dist/esm/vue.d.mts",
      "import": "./dist/esm/vue.mjs",
      "default": "./dist/esm/vue.mjs"
    },
    "./react": {
      "types": "./dist/esm/react.d.mts",
      "import": "./dist/esm/react.mjs",
      "default": "./dist/esm/react.mjs"
    },
    "./svelte": {
      "types": "./dist/esm/svelte.d.mts",
      "import": "./dist/esm/svelte.mjs",
      "default": "./dist/esm/svelte.mjs"
    },
    "./solid": {
      "types": "./dist/esm/solid.d.mts",
      "import": "./dist/esm/solid.mjs",
      "default": "./dist/esm/solid.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "fmt": "vp fmt -c oxfmt.config.ts",
    "lint": "vp lint -c oxlint.config.ts",
    "check": "vp fmt -c oxfmt.config.ts --check && vp lint -c oxlint.config.ts",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "prepublishOnly": "pnpm run check && vp pack"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "catalog:",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "solid-js": "^1.9.0",
    "svelte": "^5.0.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "solid-js": "^1.0.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
