{
  "name": "http-plugins",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": ["Axios","Plugins","Axios plugins","Enhance","Axios Enhance","Http","Xhr","Request","Axios extensions"],
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./helper": {
      "types": "./dist/helper/index.d.ts",
      "import": "./dist/helper/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*/index.d.ts",
      "import": "./dist/plugins/*/index.js"
    },
    "./objects/*": {
      "types": "./dist/objects/*/index.d.ts",
      "import": "./dist/objects/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --mode e2e",
    "mock": "bun server/dev.ts",
    "build": "tsx scripts/build.ts",
    "preview": "vite preview",
    "test": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "axios": "^1.15.2"
  },
  "dependencies": {
    "@codejoo/openapi2lang": "^1.0.6"
  }
}
