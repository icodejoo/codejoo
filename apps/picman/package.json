{
  "name": "@codejoo/picman",
  "version": "0.1.0",
  "description": "Service Worker progressive image loading library for animated formats (GIF/APNG/animated WebP), framework-agnostic.",
  "keywords": [
    "image",
    "service-worker",
    "progressive-loading",
    "gif",
    "apng",
    "webp",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icodejoo/codejoo.git",
    "directory": "apps/picman"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/esm/index.mjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": { "types": "./dist/esm/index.d.mts", "import": "./dist/esm/index.mjs", "default": "./dist/esm/index.mjs" },
    "./sw": { "types": "./dist/esm/sw.d.mts", "import": "./dist/esm/sw.mjs" },
    "./element": { "types": "./dist/esm/element.d.mts", "import": "./dist/esm/element.mjs" },
    "./shared": { "types": "./dist/esm/shared.d.mts", "import": "./dist/esm/shared.mjs" },
    "./picman-sw.js": "./dist/picman-sw.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "fmt": "vp fmt -c oxfmt.config.ts",
    "lint": "vp lint -c oxlint.config.ts",
    "check": "vp fmt -c oxfmt.config.ts --check && vp lint -c oxlint.config.ts",
    "build": "node scripts/build.mjs",
    "dev": "vp pack --watch",
    "test": "vp test",
    "prepublishOnly": "pnpm run check && vp pack"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "happy-dom": "^20.10.6",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
