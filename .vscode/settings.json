{
  // ============================================================================
  // TypeScript Native Preview (tsgo) — extension: TypeScriptTeam.native-preview
  // ============================================================================
  // 总开关 —— 必须有，否则 tsgo 扩展不启动 LSP，且内置 TS 扩展继续接管
  "js/ts.experimental.useTsgo": true,
  // 把 IDE 的 tsgo 钉到 catalog 当前版本，避免和 vp pack 错版本
  "typescript.native-preview.tsdk": "node_modules/@typescript/native-preview",
  "typescript.native-preview.trace.server": "off",
  "typescript.native-preview.showDebugInfo": true,

  // ============================================================================
  // Oxc (oxlint + oxfmt) — extension: oxc.oxc-vscode
  // ----------------------------------------------------------------------------
  // 配置文件分布（全 TS 形式，对称）：
  //   * <root>/oxlint.config.ts                  —— 共享 lint 配置
  //   * <root>/oxfmt.config.ts                   —— 共享 fmt 配置
  //   * <root>/apps/*/oxlint.config.ts           —— import root + extends + 子工程 options
  //   * <root>/apps/*/oxfmt.config.ts            —— import root + spread + 子工程覆盖
  //   * <root>/packages/*/oxlint.config.ts, oxfmt.config.ts —— 同上
  // configPath 留空 → oxc-vscode 走 nested discovery，按打开的文件向上找最近的
  // oxlint.config.ts / oxfmt.config.ts。每个文件命中最近的子工程配置（带它特有的 options）。
  // ============================================================================
  "oxc.enable": true,
  "oxc.enable.oxlint": true,
  "oxc.enable.oxfmt": true,
  "oxc.typeAware": true,
  "oxc.lint.run": "onType",
  "oxc.trace.server": "off",
  "prettier.enable": false,
  "eslint.enable": false,

  // ============================================================================
  // Format on save with oxfmt
  // ============================================================================
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "[typescript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[javascript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[json]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "oxc.oxc-vscode" },

  // ============================================================================
  // VS Code 跑 npm script 时走 vp，使其感知 vite-plus 的 task cache
  // ============================================================================
  "npm.scriptRunner": "vp",

  // ============================================================================
  // Workspace navigation
  // ============================================================================
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/.pnpm-store": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.smoke": true,
    "**/types": true,
    "**/pnpm-lock.yaml": true,
    ".claude/**": true
  }
}
